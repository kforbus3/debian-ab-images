# Provisioning server configuration. Copy to .env and edit.

# IP address of THIS provisioning server on the imaging LAN (required).
SERVER_IP=192.168.1.10

# Image to deploy — a filename present in ../output (required).
IMAGE_FILE=debian-trixie-ab.img.zst

# What each machine does after imaging: reboot | poweroff | shell
ACTION=reboot

# DHCP mode: proxy (coexist with an existing DHCP server) | dhcp (standalone)
MODE=proxy

# Restrict to one interface (recommended). Leave blank for all.
INTERFACE=eth0

# --- MODE=proxy only ---
# The subnet of the imaging LAN (network address).
PROXY_SUBNET=192.168.1.0

# --- MODE=dhcp only (standalone) ---
# DHCP_RANGE_START=192.168.50.100
# DHCP_RANGE_END=192.168.50.200
# DHCP_NETMASK=255.255.255.0
# DHCP_ROUTER=192.168.50.1
# DHCP_DNS=192.168.50.1
# LEASE_TIME=1h
