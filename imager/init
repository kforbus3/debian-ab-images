#!/bin/busybox sh
#
# Imager init: runs as PID 1 in the netboot initramfs. Brings up networking,
# downloads the A/B disk image over HTTP, writes it to the local disk, and
# reboots — fully unattended. Configured entirely via kernel command line:
#
#   imager.url=http://SERVER/images/debian-ab.img.zst   (required)
#   imager.disk=/dev/sda        target disk (default: largest non-removable disk)
#   imager.compress=auto        auto|zstd|gzip|none (default: auto from URL)
#   imager.action=reboot        reboot|poweroff|shell  (default: reboot)
#   imager.wipe=0               1 = wipe partition table before writing
#
set -u

BB=/bin/busybox
export PATH=/bin:/sbin:/usr/bin:/usr/sbin

$BB mkdir -p /proc /sys /dev /tmp /newroot
$BB mount -t proc     proc     /proc
$BB mount -t sysfs    sysfs    /sys
$BB mount -t devtmpfs devtmpfs /dev 2>/dev/null || $BB mdev -s

# Pretty console output.
RED=$(printf '\033[0;31m'); GRN=$(printf '\033[0;32m'); YEL=$(printf '\033[1;33m'); NC=$(printf '\033[0m')
say()  { echo "${GRN}[imager]${NC} $*"; }
warn() { echo "${YEL}[imager]${NC} $*"; }
die()  { echo "${RED}[imager] FATAL:${NC} $*"; echo "Dropping to a shell."; exec $BB sh; }

banner() {
    echo
    echo "  ┌──────────────────────────────────────────┐"
    echo "  │   Debian A/B Network Imager                │"
    echo "  └──────────────────────────────────────────┘"
    echo
}

# --- Parse kernel cmdline ---
getarg() {
    for x in $(cat /proc/cmdline); do
        case "$x" in "$1="*) echo "${x#*=}"; return 0;; esac
    done
    echo "$2"
}

banner
IMG_URL="$(getarg imager.url '')"
TARGET="$(getarg imager.disk '')"
COMPRESS="$(getarg imager.compress auto)"
ACTION="$(getarg imager.action reboot)"
WIPE="$(getarg imager.wipe 0)"

[ -n "$IMG_URL" ] || die "imager.url= not set on the kernel command line"

# --- Load hardware modules (network + storage), best-effort ---
say "Loading hardware drivers…"
if [ -d /lib/modules ]; then
    KVER="$(ls /lib/modules | head -n1)"
    # depmod so modprobe can resolve dependencies.
    $BB depmod -a "$KVER" 2>/dev/null || true
    for m in virtio_pci virtio_net virtio_blk virtio_scsi \
             e1000 e1000e igb igc ixgbe tg3 r8169 atlantic bnx2 bnx2x \
             ahci sd_mod nvme nvme_core xhci_pci ehci_pci usb_storage \
             ext4 mii; do
        $BB modprobe "$m" 2>/dev/null || true
    done
fi
$BB mdev -s 2>/dev/null || true
$BB sleep 2

# --- Bring up networking via DHCP on every ethernet link ---
say "Configuring network (DHCP)…"
for dev in $($BB ls /sys/class/net); do
    [ "$dev" = "lo" ] && continue
    $BB ip link set "$dev" up 2>/dev/null || true
done
$BB sleep 3
GOT_IP=0
for dev in $($BB ls /sys/class/net); do
    [ "$dev" = "lo" ] && continue
    $BB udhcpc -i "$dev" -q -t 8 -T 2 -s /usr/share/udhcpc/default.script >/dev/null 2>&1 || true
    # Only accept the interface if it actually received an IPv4 address.
    if $BB ip -4 addr show "$dev" 2>/dev/null | $BB grep -q "inet "; then
        GOT_IP=1
        say "Network up on $dev: $($BB ip -o -4 addr show "$dev" | $BB awk '{print $4}')"
        break
    fi
done
[ "$GOT_IP" = 1 ] || die "DHCP failed on all interfaces (no IPv4 lease applied)"

# --- Choose the target disk ---
if [ -z "$TARGET" ]; then
    say "Auto-selecting target disk (largest non-removable)…"
    BEST=""; BEST_SZ=0
    for d in /sys/block/*; do
        name="$($BB basename "$d")"
        case "$name" in loop*|ram*|sr*|fd*|dm-*|md*) continue;; esac
        [ "$(cat "$d/removable" 2>/dev/null)" = "1" ] && continue
        sz="$(cat "$d/size" 2>/dev/null || echo 0)"
        if [ "$sz" -gt "$BEST_SZ" ]; then BEST_SZ="$sz"; BEST="/dev/$name"; fi
    done
    TARGET="$BEST"
fi
[ -n "$TARGET" ] && [ -b "$TARGET" ] || die "No suitable target disk found (set imager.disk=)"
TARGET_GB=$(( $(cat /sys/block/$($BB basename $TARGET)/size) * 512 / 1000000000 ))
say "Target disk: ${TARGET} (~${TARGET_GB} GB)"

# --- Decide decompressor ---
case "$COMPRESS" in
    auto) case "$IMG_URL" in *.zst) DECOMP="zstd -d";; *.gz) DECOMP="gzip -d";; *) DECOMP="cat";; esac;;
    zstd) DECOMP="zstd -d";; gzip) DECOMP="gzip -d";; none) DECOMP="cat";;
    *) DECOMP="cat";;
esac

if [ "$WIPE" = "1" ]; then
    say "Wiping existing partition table on ${TARGET}"
    $BB dd if=/dev/zero of="$TARGET" bs=1M count=16 conv=fsync 2>/dev/null || true
fi

# --- Stream the image to disk ---
say "Writing image to ${TARGET}"
say "Source: ${IMG_URL}"
echo "${YEL}  This can take a few minutes; do not power off.${NC}"
$BB wget -O - "$IMG_URL" | $DECOMP | $BB dd of="$TARGET" bs=4M conv=fsync 2>&1
$BB sync

# Integrity check: a GPT image must leave the "EFI PART" signature at LBA1.
# This catches a failed/partial download that dd would otherwise report as success.
if $BB dd if="$TARGET" bs=1 skip=512 count=8 2>/dev/null | $BB grep -aq "EFI PART"; then
    say "${GRN}Image written successfully (GPT verified).${NC}"
else
    die "Imaging failed: no valid GPT on ${TARGET} (download/URL problem?)"
fi

# Re-read the partition table so the kernel sees the new layout.
$BB blockdev --rereadpt "$TARGET" 2>/dev/null || true

case "$ACTION" in
    shell) say "Done. Dropping to a shell (imager.action=shell)."; exec $BB sh;;
    poweroff) say "Done. Powering off in 5s…"; $BB sleep 5; $BB poweroff -f;;
    *) say "Done. Rebooting in 5s…"; $BB sleep 5; $BB reboot -f;;
esac
