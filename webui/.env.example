# Web UI configuration. Copy to webui/.env and edit.

# Login password for the UI (single admin).
ADMIN_PASSWORD=admin

# Random secret for signing sessions:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-this-to-a-long-random-string

# ABSOLUTE host path to this repository (required). Example:
HOST_PROJECT_DIR=/opt/debian-ab-images
